def is_prime(n):
    for i in range(2, n):
        if n % i == 0:
            return False
    return True

def sum_of_digits(n):
    n = abs(n) // нововедение, объясни чем это обусловено и зачем надо
    total = 0
    while n > 0:
        total += n % 10
        n //= 10
    return total
